# Copy to .env and fill in to use the live Claude backend.
# Leave LLM_BACKEND=mock to run fully offline (no key needed).

LLM_BACKEND=mock
# LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=2000

# TTL orchestration tuning
PLAN_CANDIDATES_N=4
CB_CONSECUTIVE_FAILS=3
CB_FAILURE_THRESHOLD=5
CB_COOLDOWN_SECONDS=30
SOFT_TIMEOUT_SECONDS=20
HARD_TIMEOUT_SECONDS=40
WATCHDOG_MAX_RETRIES=1

# Verifier
BUDGET_TOLERANCE=0.0
BUDGET_FLOOR_FRACTION=0.25
